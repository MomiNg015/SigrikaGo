    "lucide-react": "^0.511.0",
    "multer": "^2.1.1",
    "prisma": "6.8.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "vite": "^6.3.5",
