generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  username           String   @unique
  passwordHash       String
  rank               String   @default("18级")
  rating             Int      @default(1000)
  wins               Int      @default(0)
  losses             Int      @default(0)
  coins              Int      @default(300)
  selectedCharacter  String   @default("sigrika")
  ownedCharacters    String   @default("sigrika,danea,aemeath")
  ownedItems         String   @default("")
  ownedDecorations   String   @default("")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model GameRecord {
  id          String   @id @default(cuid())
  roomCode    String
  blackUserId String
  whiteUserId String
  blackName   String
  whiteName   String
  blackCharacter String
  whiteCharacter String
  resultText  String
  moveCount   Int
  snapshot    String
  createdAt   DateTime @default(now())
}
