generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  username           String   @unique
  passwordHash       String
  role               String   @default("player")
  status             String   @default("active")
  banReason          String?
  bannedAt           DateTime?
  rank               String   @default("2段")
  rating             Int      @default(1000)
  wins               Int      @default(0)
  losses             Int      @default(0)
  coins              Int      @default(300)
  selectedCharacter  String   @default("sigrika")
  selectedStoneDecoration String @default("")
  ownedCharacters    String   @default("sigrika,danea,aemeath")
  ownedItems         String   @default("")
  ownedDecorations   String   @default("")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserRelationship {
  id           String   @id @default(cuid())
  ownerUserId  String
  targetUserId String
  type         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([ownerUserId, targetUserId])
  @@index([ownerUserId, type])
  @@index([targetUserId])
}

model GameRecord {
  id          String   @id @default(cuid())
  roomCode    String
  blackUserId String
  whiteUserId String
  blackName   String
  whiteName   String
  blackCharacter String
  whiteCharacter String
  resultText  String
  winnerColor String?
  resultReason String?
  moveCount   Int
  snapshot    String
  snapshotVersion Int @default(1)
  createdAt   DateTime @default(now())
}

model Character {
  id             String          @id @default(cuid())
  slug           String          @unique
  name           String
  portraitUrl    String
  portraitSource String          @default("url")
  acquisitionMethod String       @default("")
  palette        String          @default("#5d7fe8")
  enabled        Boolean         @default(true)
  sortOrder      Int             @default(0)
  skill          CharacterSkill?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model CharacterSkill {
  id          String    @id @default(cuid())
  characterId String    @unique
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  effectType  String
  name        String
  description String
  uses        Int       @default(1)
  freeTurn    Boolean   @default(false)
  targetRule  String
  paramsJson  String    @default("{}")
  costType    String    @default("numeric")
  costValue   String    @default("0")
  systemMessage String   @default("{fromColor}{player}使用了{character}的“{skill}”技能，目标是{point}。")
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Decoration {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @default("")
  imageUrl    String   @default("")
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ShopItem {
  id              String   @id @default(cuid())
  name            String
  category        String
  targetId        String
  priceCoins      Int
  discountPercent Int      @default(0)
  purchasable     Boolean  @default(true)
  enabled         Boolean  @default(true)
  sortOrder       Int      @default(0)
  description     String   @default("")
  imageUrl         String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  targetType  String
  targetId    String
  beforeJson  String?
  afterJson   String?
  createdAt   DateTime @default(now())
}

model SiteSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeedbackMessage {
  id        String   @id @default(cuid())
  userId    String
  username  String
  content   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}
